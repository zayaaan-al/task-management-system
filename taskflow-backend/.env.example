# TaskFlow Backend — .env Template
# Copy this file to .env and fill in your values

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (for production)
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/taskflow
MONGO_URI=mongodb://localhost:27017/taskflow

# JWT Secret — use a long, random string in production (min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
